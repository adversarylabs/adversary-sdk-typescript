{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.adversarylabs.com/adversary.input.v1.schema.json",
  "title": "Adversary Input",
  "type": "object",
  "additionalProperties": true,
  "required": ["source"],
  "properties": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
