{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.adversarylabs.com/adversary.run.v1.schema.json",
  "title": "Adversary Run Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "result"],
  "properties": {
    "protocolVersion": { "const": 1 },
    "result": { "$ref": "#/$defs/reviewResult" }
  },
  "$defs": {
    "severity": {
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "confidence": {
      "enum": ["low", "medium", "high"]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "location": { "$ref": "#/$defs/location" },
        "label": { "type": "string" },
        "message": { "type": "string" },
        "snippet": { "type": "string" },
        "data": { "type": "object", "additionalProperties": true }
      }
    },
    "evidenceInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "location": { "$ref": "#/$defs/location" },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "label": { "type": "string" },
        "message": { "type": "string" },
        "snippet": { "type": "string" },
        "data": { "type": "object", "additionalProperties": true },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "complexity": {
          "enum": ["trivial", "small", "medium", "large", "architectural"]
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "category", "severity", "confidence", "summary", "evidence"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "ruleId": { "type": "string", "minLength": 1 },
        "groupKey": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/severity" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "summary": { "type": "string", "minLength": 1 },
        "whyItMatters": { "type": "string" },
        "impact": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "recommendation": { "type": "string" },
        "remediation": { "$ref": "#/$defs/remediation" },
        "synthesisSource": { "enum": ["rule", "generic"] },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "reviewNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "summary"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence" }
        },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk"],
      "properties": {
        "risk": { "enum": ["none", "low", "medium", "high", "critical"] },
        "summary": { "type": "string" }
      }
    },
    "opinion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "ship": { "type": "boolean" },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "score"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "score": { "type": "number" },
        "max": { "type": "number" },
        "summary": { "type": "string" }
      }
    },
    "observationTitle": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["singular", "plural"],
          "properties": {
            "singular": { "type": "string", "minLength": 1 },
            "plural": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "observationSummary": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "singular": { "type": "string" },
            "grouped": { "type": "string" }
          }
        }
      ]
    },
    "recommendationInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "details": { "type": "string" }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ruleId", "subject", "title"],
      "properties": {
        "ruleId": { "type": "string", "minLength": 1 },
        "subject": { "type": "string", "minLength": 1 },
        "groupKey": { "type": "string" },
        "groupBy": { "type": "array", "items": { "type": "string" } },
        "groupedTitle": { "type": "string" },
        "deduplicate": { "type": "boolean" },
        "category": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "confidence": {
          "oneOf": [
            { "$ref": "#/$defs/confidence" },
            { "type": "number", "minimum": 0, "maximum": 1 }
          ]
        },
        "confidenceAggregation": { "enum": ["maximum", "minimum", "average"] },
        "severityAggregation": { "enum": ["highest", "lowest"] },
        "title": { "$ref": "#/$defs/observationTitle" },
        "summary": { "$ref": "#/$defs/observationSummary" },
        "whyItMatters": { "type": "string" },
        "impact": { "type": "string" },
        "location": { "$ref": "#/$defs/evidenceInput" },
        "evidence": {
          "oneOf": [{ "type": "string" }, { "type": "object", "additionalProperties": true }]
        },
        "recommendation": {
          "oneOf": [{ "type": "string" }, { "$ref": "#/$defs/recommendationInput" }]
        },
        "remediation": { "$ref": "#/$defs/remediation" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "metadata": { "type": "object", "additionalProperties": true }
      }
    },
    "reviewResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "adversary",
        "target",
        "positives",
        "observations",
        "findings",
        "suppressed"
      ],
      "properties": {
        "schemaVersion": { "const": "adversary.review.v1" },
        "adversary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string" }
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "repository": { "type": "string" },
            "filesScanned": { "type": "number" }
          }
        },
        "assessment": { "$ref": "#/$defs/assessment" },
        "positives": { "type": "array", "items": { "$ref": "#/$defs/reviewNote" } },
        "observations": { "type": "array", "items": { "$ref": "#/$defs/reviewNote" } },
        "scores": { "type": "array", "items": { "$ref": "#/$defs/score" } },
        "findings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
        "opinion": { "$ref": "#/$defs/opinion" },
        "suppressed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["observations", "findings"],
          "properties": {
            "observations": { "type": "integer", "minimum": 0 },
            "findings": { "type": "integer", "minimum": 0 }
          }
        },
        "timing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "buildMs": { "type": "number", "minimum": 0 },
            "startupMs": { "type": "number", "minimum": 0 },
            "scanMs": { "type": "number", "minimum": 0 },
            "totalMs": { "type": "number", "minimum": 0 }
          }
        },
        "suppressedFindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        },
        "rawObservations": {
          "type": "array",
          "items": { "$ref": "#/$defs/observation" }
        }
      }
    }
  }
}
