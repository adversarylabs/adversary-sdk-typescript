{
  "name": "@adversarylabs/sdk",
  "version": "0.1.7",
  "description": "Small TypeScript SDK for authoring Adversaries.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adversarylabs/adversary-sdk-typescript.git"
  },
  "homepage": "https://github.com/adversarylabs/adversary-sdk-typescript#readme",
  "bugs": {
    "url": "https://github.com/adversarylabs/adversary-sdk-typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/adversary.manifest.v1": "./schemas/adversary.manifest.v1.schema.json",
    "./schemas/adversary.input.v1": "./schemas/adversary.input.v1.schema.json",
    "./schemas/adversary.review.v1": "./schemas/adversary.review.v1.schema.json"
  },
  "files": ["dist", "schemas", "templates", "README.md"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && vitest run",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.8.1"
  }
}
